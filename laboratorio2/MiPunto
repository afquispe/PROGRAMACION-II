package com.mycompany.laboratoio1.labo2;

/**
 *
 * @author Usuario
 */
public class MiPunto {
    
    private double x;
    private double y;
    public MiPunto(){
        this.x=0;
        this.y=0;
        
    }
    public MiPunto(double x,double y){
        this.x=x;
        this.y=y;
    }
    public double distancia (MiPunto o){
        double dx= this.x- o.x;
        double dy= this.y- o.y;
        return Math.sqrt(dx*dx+dy*dy);
    }
    public double distancia (double x,double y){
        double dx= this.x- x;
        double dy= this.y- y;
        return Math.sqrt(dx*dx+dy*dy);
    }
    
    public static void main(String[] args){
        MiPunto p1=new MiPunto();
        MiPunto p2=new MiPunto(3,4);
        
        System.out.println("Distancia de p1 a p2: " +p1.distancia(p2));
        System.out.println("Distancia p2 a (5,2): "+ p2.distancia(5,2));
    }
}
